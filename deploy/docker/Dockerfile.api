FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN addgroup --system synapses && adduser --system --ingroup synapses synapses

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY synapses /app/synapses

USER synapses
EXPOSE 8000

CMD ["uvicorn", "synapses.api:app", "--host", "0.0.0.0", "--port", "8000"]
